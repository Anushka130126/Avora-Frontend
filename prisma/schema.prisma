generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  ADMIN
  PM
  DEVELOPER
  CLIENT
}

enum ClientTier {
  STARTUP
  SCALE_UP
  ENTERPRISE
}

enum ProjectType {
  CUSTOM_DEV
  AI_SOLUTION
  DATA_ANALYTICS
  BPO
}

enum ProjectStatus {
  DISCOVERY
  IN_PROGRESS
  QA
  DEPLOYED
  COMPLETED
}

enum TaskType {
  CODE_REVIEW
  MODEL_TRAINING
  DATA_PROCESSING
  DEPLOYMENT
  GENERAL
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AiFramework {
  PYTORCH
  TENSORFLOW
  LLAMA2
  GPT_4_API
  OTHER
}

enum VentureStage {
  IDEATION
  MVP
  SCALING
  SPUN_OUT
}

// ==========================================
// COMPOSITE TYPES (MongoDB specific)
// ==========================================

type Timeline {
  start    DateTime
  deadline DateTime
}

type Milestone {
  name         String
  deliverables String[]
  dueDate      DateTime
  completed    Boolean  @default(false)
}

type ProjectAiModel {
  type     String
  endpoint String
  accuracy Float?
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String?  // For Credentials provider testing
  role         UserRole @default(DEVELOPER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // A Client-role user belongs to a specific company
  clientId     String?  @db.ObjectId
  client       Client?  @relation(fields: [clientId], references: [id])

  // A developer or PM can be assigned to multiple projects
  projectIds   String[]  @db.ObjectId
  projects     Project[] @relation("ProjectTeam", fields: [projectIds], references: [id])

  tasks        Task[]    @relation("TaskAssignee")
  timesheets   Timesheet[]
  ventures     Venture[]
}

model Client {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String
  company       String
  tier          ClientTier
  projectsCount Int        @default(0)
  totalRevenue  Float      @default(0.0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  users         User[]     // Client portals/logins
  projects      Project[]
}

model Project {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  type         ProjectType
  status       ProjectStatus    @default(DISCOVERY)
  budget       Float
  timeline     Timeline
  milestones   Milestone[]
  aiModels     ProjectAiModel[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  clientId     String           @db.ObjectId
  client       Client           @relation(fields: [clientId], references: [id])

  teamIds      String[]         @db.ObjectId
  teamAssigned User[]           @relation("ProjectTeam", fields: [teamIds], references: [id])

  tasks        Task[]
  models       AiModelRegistry[]
  timesheets   Timesheet[]
}

model Task {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  type            TaskType
  status          TaskStatus   @default(BACKLOG)
  priority        TaskPriority @default(MEDIUM)
  estimatedHours  Float
  actualHours     Float        @default(0.0)
  dueDate         DateTime?
  linkedResources String[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  projectId       String       @db.ObjectId
  project         Project      @relation(fields: [projectId], references: [id])
  
  assignedToId    String?      @db.ObjectId
  assignedTo      User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])
}

model AiModelRegistry {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  framework          AiFramework
  endpoint           String
  accuracy           Float?
  latency_ms         Int?
  deployedDate       DateTime?
  cost_per_inference Float?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  projectId          String?     @db.ObjectId
  project            Project?    @relation(fields: [projectId], references: [id])
}

model Timesheet {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  hoursLogged     Float
  date            DateTime
  taskDescription String
  billable        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  employeeId      String   @db.ObjectId
  employee        User     @relation(fields: [employeeId], references: [id])
  
  projectId       String   @db.ObjectId
  project         Project  @relation(fields: [projectId], references: [id])
}

model Venture {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  problem       String
  vision        String
  stage         VentureStage @default(IDEATION)
  fundingTarget Float
  capTable      Json
  marketData    Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  founderId     String       @db.ObjectId
  founder       User         @relation(fields: [founderId], references: [id])
}
